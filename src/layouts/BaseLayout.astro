---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const { displayPageName, activePage, pageTitle } = Astro.props;
---

<!doctype html>
<html>
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, shrink-to-fit=no"
		/>
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />

		<title>{pageTitle}</title>
		<meta
			name="description"
			content="Personal website of Stefan Grünewald"
		/>

	</head>

	<body>
		<!-- Header -->
		<Header displayPageName={displayPageName} activePage={activePage} />

		<!-- Content -->
		<slot />

		<!-- Footer -->
		<Footer />

	</body>
</html>
