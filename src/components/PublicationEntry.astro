---
interface Props {
  pub: {
    key: string;
    title: string;
    author: string[];
    abbr?: string;
    type?: string;
    booktitle?: string;
    abstract?: string;
    eprint?: string;
    pdf?: string;
    poster?: string;
    slides?: string;
  };
  coauthors: Record<string, { url: string }>;
  venues: Record<string, { url: string }>;
}

const { pub, coauthors, venues } = Astro.props;

function formatAuthors(authors: string[], coauthors: Record<string, { url: string }>) {
  const formatted = authors.map((name) => {
    if (name === "Stefan Grünewald") {
      return `<em>${name}</em>`;
    }
    const lastName = name.split(" ").at(-1)!;
    if (coauthors[lastName]) {
      return `<a href="${coauthors[lastName].url}" target="_blank">${name}</a>`;
    }
    return name;
  });

  if (formatted.length === 1) return formatted[0];
  if (formatted.length === 2) return formatted.join(" and ");
  return formatted.slice(0, -1).join(", ") + ", and " + formatted.at(-1);
}
---

<li>
  <div class="row">
    <div class="col-sm-2 abbr">
      {pub.abbr && venues[pub.abbr] ? (
        <abbr class={`badge ${pub.abbr.toLowerCase()}`}>
          <a href={venues[pub.abbr].url} target="_blank">{pub.abbr}</a>
        </abbr>
      ) : pub.abbr ? (
        <abbr class="badge">{pub.abbr}</abbr>
      ) : null}
    </div>

    <div id={pub.key} class="col-sm-8">
      <span class="title">{pub.title}</span>
      <span class="author" set:html={formatAuthors(pub.author, coauthors)} />
      {pub.type === "inproceedings" && pub.booktitle && (
        <span class="periodical">
          <em>In: {pub.booktitle}</em>
        </span>
      )}

      <span class="links">
        {pub.abstract && (
          <Fragment>[<a class="abstract">Abstract</a>] </Fragment>
        )}
        {pub.eprint && (
          <Fragment>[<a href={`https://arxiv.org/abs/${pub.eprint}`} target="_blank">arXiv</a>] </Fragment>
        )}
        {pub.pdf && (
          <Fragment>[<a href={`/assets/pdf/${pub.pdf}`} target="_blank">PDF</a>] </Fragment>
        )}
        {pub.poster && (
          <Fragment>[<a href={`/assets/pdf/${pub.poster}`} target="_blank">Poster</a>] </Fragment>
        )}
        {pub.slides && (
          <Fragment>[<a href={`/assets/pdf/${pub.slides}`} target="_blank">Slides</a>] </Fragment>
        )}
      </span>

      {pub.abstract && (
        <span class="abstract hidden">
          <p>{pub.abstract}</p>
        </span>
      )}
    </div>
  </div>
</li>

<style>
  li {
    margin-bottom: 1rem;
  }

  .abbr {
    height: 2rem;
    margin-bottom: 0.5rem;
  }

  .abbr abbr {
    display: inline-block;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  abbr a {
    color: black;
  }
  abbr a:hover {
    color: black;
  }

  .acl { background-color: #bb342f; }
  .eacl { background-color: #bb342f; }
  .iwpt { background-color: #5c9ead; }
  .udw { background-color: #5c9ead; }
  .wiesp { background-color: #5c9ead; }
  .arxiv { background-color: #f17300; }
  .conll { background-color: #bb342f; }
  .law { background-color: #5c9ead; }
  .findings { background-color: #5c9ead; }

  span {
    display: block;
  }

  .title {
    font-weight: bolder;
  }

  .author a {
    border-bottom: 1px dashed #bb342f;
  }
  .author a:hover {
    border-bottom-style: solid;
    text-decoration: none;
  }
  .author > em {
    font-style: normal;
  }

  em.star {
    border-bottom: none;
    color: #bb342f;
    font-style: normal;
  }

  a.abstract, a.bibtex {
    cursor: pointer;
  }

  .hidden {
    font-size: 0.875rem;
    height: 0px;
    overflow: hidden;
    text-align: justify;
    transition: all 0.15s ease;
  }
  .hidden p {
    line-height: 1.4em;
    margin: 10px;
  }
  .hidden pre {
    font-size: 1em;
    line-height: 1.4em;
    padding: 10px;
  }
  .hidden.open {
    height: auto;
  }
  span.abstract.hidden {
    border: none;
  }
  span.abstract.hidden.open {
    border: dashed 1px;
    border-color: #828282;
  }
</style>
